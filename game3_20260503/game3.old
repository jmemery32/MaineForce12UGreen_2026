function showTab(id,btn){
  document.querySelectorAll('.tab-panel').forEach(p=>p.classList.remove('active'));
  document.querySelectorAll('.tab-btn').forEach(b=>b.classList.remove('active'));
  document.getElementById(id).classList.add('active');
  btn.classList.add('active');
}
let _aid=null;
function openPicker(id,name,inn){
  _aid=id;
  document.getElementById('ptitle').textContent=name+' · Inn '+(inn+1);
  document.getElementById('ov').classList.add('open');
}
function closeOv(){document.getElementById('ov').classList.remove('open');_aid=null;}
function pick(pos){
  if(!_aid)return;
  const el=document.getElementById(_aid);
  el.textContent=pos;
  el.className='pc '+sf(pos);
  closeOv();
}
document.getElementById('ov').addEventListener('click',e=>{if(e.target===document.getElementById('ov'))closeOv();});
function sf(v){return v==='P'?'pst':v==='C'?'cst':v==='SIT'?'sst':'';}

function renderTable(cid,data,notes){
  const div=document.getElementById(cid);
  if(!div)return;
  let h='<table><thead><tr><th>Bat</th><th>Player</th><th>Inn 1</th><th>Inn 2</th><th>Inn 3</th><th>Inn 4</th><th>Inn 5</th><th>Inn 6</th></tr></thead><tbody>';
  data.forEach((row,pi)=>{
    const[bat,name,...inns]=row;
    const cells=inns.map((v,i)=>{
      const id=`${cid}-r${pi}-i${i}`;
      return`<td><span class="pc ${sf(v)}" id="${id}" onclick="openPicker('${id}','${name}',${i})">${v}</span></td>`;
    }).join('');
    h+=`<tr><td>${bat}</td><td>${name}</td>${cells}</tr>`;
  });
  h+='</tbody></table>';
  if(notes&&notes.length)h+='<div class="nrow">'+notes.map(n=>`<span class="nb">${n}</span>`).join('')+'</div>';
  div.innerHTML=h;
}

renderTable('tbl-426g1-g2',p426g1_g2,['GOES 2','Sam P 1-2','Ben P 3-4','Alex P 5','Owen P 6','Joe C 1-3','Charlie C 4-6']);
