<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Maine Force 12U Green · 2026</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=Oswald:wght@400;600;700&family=Source+Code+Pro:wght@400;600&display=swap');
:root{--green:#1a3a1a;--chalk:#ffffff;--accent:#e8c840;--blue:#90ccff;--purple:#cc99ff;}
*{box-sizing:border-box;margin:0;padding:0;}
body{background:var(--green);background-image:repeating-linear-gradient(0deg,transparent,transparent 39px,rgba(255,255,255,.03) 39px,rgba(255,255,255,.03) 40px);font-family:'Source Code Pro',monospace;color:var(--chalk);padding:20px 12px 60px;min-height:100vh;}
h1{font-family:'Oswald',sans-serif;font-size:1.8rem;font-weight:700;letter-spacing:.12em;text-transform:uppercase;text-align:center;color:var(--accent);margin-bottom:4px;}
.subtitle{text-align:center;font-family:'Oswald',sans-serif;font-size:.72rem;letter-spacing:.2em;color:rgba(255,255,255,.3);margin-bottom:24px;text-transform:uppercase;}
.tabs{display:flex;justify-content:center;gap:6px;margin-bottom:20px;flex-wrap:wrap;}
.tab-btn{font-family:'Oswald',sans-serif;font-size:.76rem;font-weight:600;letter-spacing:.06em;text-transform:uppercase;background:transparent;border:2px solid rgba(255,255,255,.18);color:rgba(255,255,255,.45);padding:6px 12px;border-radius:4px;cursor:pointer;transition:all .15s;}
.tab-btn.active{background:var(--accent);border-color:var(--accent);color:var(--green);}
.tab-btn:hover:not(.active){border-color:var(--accent);color:var(--accent);}
.tab-panel{display:none;}.tab-panel.active{display:block;}
.date-hdr{font-family:'Oswald',sans-serif;font-size:.95rem;letter-spacing:.15em;color:rgba(255,255,255,.38);text-align:center;margin-bottom:12px;text-transform:uppercase;}
.slbl{font-family:'Oswald',sans-serif;font-size:.65rem;letter-spacing:.16em;text-transform:uppercase;color:var(--accent);margin-bottom:4px;padding-left:2px;}
.card{background:rgba(0,0,0,.28);border:1px solid rgba(255,255,255,.07);border-radius:8px;padding:12px;margin-bottom:16px;overflow-x:auto;}
.legend{display:flex;gap:10px;flex-wrap:wrap;margin-bottom:8px;font-size:.66rem;font-family:'Oswald',sans-serif;letter-spacing:.07em;}
.leg{border-radius:3px;padding:2px 6px;}
.leg-p{background:rgba(100,180,255,.18);color:var(--blue);}
.leg-c{background:rgba(180,100,255,.18);color:var(--purple);}
.leg-s{background:rgba(232,200,64,.14);color:var(--accent);}
table{width:100%;border-collapse:collapse;font-size:.7rem;white-space:nowrap;}
thead th{font-family:'Oswald',sans-serif;font-size:.66rem;letter-spacing:.1em;text-transform:uppercase;color:var(--accent);padding:5px 7px;border-bottom:1px solid rgba(232,200,64,.2);text-align:center;font-weight:600;}
thead th:nth-child(1),thead th:nth-child(2){text-align:left;}
tbody tr:nth-child(even){background:rgba(255,255,255,.03);}
tbody tr:hover{background:rgba(232,200,64,.06);}
tbody td{padding:3px 5px;text-align:center;border-bottom:1px solid rgba(255,255,255,.04);}
tbody td:nth-child(1){text-align:left;color:var(--accent);font-weight:600;font-size:.65rem;width:24px;}
tbody td:nth-child(2){text-align:left;font-family:'Oswald',sans-serif;font-size:.8rem;letter-spacing:.04em;color:var(--chalk);padding-right:10px;min-width:76px;}
.pc{display:inline-block;min-width:40px;padding:3px 5px;border-radius:3px;cursor:pointer;font-family:'Oswald',sans-serif;font-size:.74rem;font-weight:600;letter-spacing:.04em;border:1px solid rgba(255,255,255,.1);background:rgba(255,255,255,.05);color:rgba(255,255,255,.7);transition:background .1s;user-select:none;}
.pc:hover{background:rgba(255,255,255,.14);}
.pst{background:rgba(100,180,255,.18)!important;color:var(--blue)!important;border-color:rgba(100,180,255,.3)!important;}
.cst{background:rgba(180,100,255,.18)!important;color:var(--purple)!important;border-color:rgba(180,100,255,.3)!important;}
.sst{background:rgba(232,200,64,.13)!important;color:var(--accent)!important;border-color:rgba(232,200,64,.28)!important;}
.overlay{display:none;position:fixed;inset:0;z-index:200;background:rgba(0,0,0,.55);align-items:center;justify-content:center;}
.overlay.open{display:flex;}
.pbox{background:#1e3a1e;border:1px solid rgba(232,200,64,.4);border-radius:10px;padding:14px;min-width:240px;box-shadow:0 8px 40px rgba(0,0,0,.6);}
.ptitle{font-family:'Oswald',sans-serif;font-size:.8rem;letter-spacing:.12em;text-transform:uppercase;color:var(--accent);margin-bottom:10px;text-align:center;}
.pgrid{display:grid;grid-template-columns:repeat(4,1fr);gap:7px;}
.pb{font-family:'Oswald',sans-serif;font-size:.78rem;font-weight:600;letter-spacing:.05em;padding:8px 4px;border-radius:4px;border:1px solid rgba(255,255,255,.13);background:rgba(255,255,255,.07);color:var(--chalk);cursor:pointer;transition:all .1s;text-align:center;}
.pb:hover{background:var(--accent);color:var(--green);border-color:var(--accent);}
.pb.pp{background:rgba(100,180,255,.2);color:var(--blue);border-color:rgba(100,180,255,.3);}
.pb.cp{background:rgba(180,100,255,.2);color:var(--purple);border-color:rgba(180,100,255,.3);}
.pb.sp{background:rgba(232,200,64,.15);color:var(--accent);border-color:rgba(232,200,64,.28);}
.pcancel{margin-top:8px;width:100%;font-family:'Oswald',sans-serif;font-size:.72rem;letter-spacing:.1em;padding:7px;border-radius:4px;border:1px solid rgba(255,255,255,.12);background:transparent;color:rgba(255,255,255,.38);cursor:pointer;}
.pcancel:hover{color:var(--chalk);}
.nrow{display:flex;flex-wrap:wrap;gap:5px;margin-top:9px;padding-top:9px;border-top:1px solid rgba(255,255,255,.06);}
.nb{border:1px solid rgba(232,200,64,.45);border-radius:3px;font-family:'Oswald',sans-serif;font-size:.65rem;letter-spacing:.06em;color:var(--accent);padding:2px 8px;}
.igrid{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:16px;}
@media(max-width:460px){.igrid{grid-template-columns:1fr;}}
.ib h4{font-family:'Oswald',sans-serif;font-size:.68rem;letter-spacing:.13em;text-transform:uppercase;color:var(--accent);margin-bottom:6px;border-bottom:1px solid rgba(232,200,64,.18);padding-bottom:3px;}
.ib li{font-size:.73rem;color:rgba(255,255,255,.75);line-height:1.9;list-style:none;}
.ib li .n{display:inline-block;width:22px;color:var(--accent);font-weight:600;}
.rnum{text-align:center!important;font-family:'Oswald',sans-serif;font-size:.95rem;color:var(--accent)!important;}
</style>
</head>
<body>
<h1>⚾ Maine Force 12U Green</h1>
<p class="subtitle">2026 Season · Tap any cell to edit position</p>

<div class="tabs">
  <button class="tab-btn active" onclick="showTab('roster',this)">Roster</button>
  <button class="tab-btn" onclick="showTab('g1-426',this)">4/26 G1</button>
  <button class="tab-btn" onclick="showTab('g2-426',this)">4/26 G2</button>
  <button class="tab-btn" onclick="showTab('g1-502',this)">5/3 G1</button>
  <button class="tab-btn" onclick="showTab('g1-502-notes',this)">5/3 G1 Notes</button>
  <button class="tab-btn" onclick="showTab('g2-502',this)">5/3 G2</button>
  <button class="tab-btn" onclick="showTab('g2-502-notes',this)">5/3 G2 Notes</button>
</div>

<div class="overlay" id="ov">
  <div class="pbox">
    <div class="ptitle" id="ptitle">Select Position</div>
    <div class="pgrid">
      <button class="pb pp" onclick="pick('P')">P</button>
      <button class="pb cp" onclick="pick('C')">C</button>
      <button class="pb" onclick="pick('1B')">1B</button>
      <button class="pb" onclick="pick('2B')">2B</button>
      <button class="pb" onclick="pick('3B')">3B</button>
      <button class="pb" onclick="pick('SS')">SS</button>
      <button class="pb" onclick="pick('LF')">LF</button>
      <button class="pb" onclick="pick('CF')">CF</button>
      <button class="pb" onclick="pick('RF')">RF</button>
      <button class="pb sp" onclick="pick('SIT')">SIT</button>
    </div>
    <button class="pcancel" onclick="closeOv()">Cancel</button>
  </div>
</div>

<!-- ROSTER -->
<div class="tab-panel active" id="roster">
